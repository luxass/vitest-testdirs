{
  "name": "vitest-testdirs",
  "version": "4.4.3",
  "description": "A utility for Vitest to create isolated test directories",
  "type": "module",
  "author": {
    "name": "Lucas Nørgård",
    "email": "lucasnrgaard@gmail.com",
    "url": "https://luxass.dev"
  },
  "packageManager": "pnpm@10.32.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luxass/vitest-testdirs.git"
  },
  "keywords": [
    "vitest",
    "testdirs"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./helpers": "./dist/helpers.mjs",
    "./vitest": "./dist/vitest.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vitest": ">=3.0.0 <4.0.0 || >=4.0.0 <5.0.0"
  },
  "dependencies": {
    "testdirs": "^4.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@luxass/eslint-config": "^7.3.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-format": "^2.0.1",
    "publint": "^0.3.18",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
